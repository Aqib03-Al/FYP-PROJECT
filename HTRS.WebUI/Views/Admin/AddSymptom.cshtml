@{
    ViewData["Title"] = "Add Symptom";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">Add New Symptom</h3>
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Symptom Name</label>
                            <input type="text" name="Name" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Body Part</label>
                            <input type="text" name="BodyPart" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea name="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Save Symptom</button>
                    </form>
                    <div class="text-center mt-2">
                        <a asp-action="Symptoms" class="btn btn-link">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
