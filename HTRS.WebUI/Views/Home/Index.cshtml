@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<!-- ✅ Hero Section -->
<div class="bg-primary text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">🏥 Health Test Recommendation System</h1>
        <p class="lead mt-3">
            Get personalized medical test recommendations based on your symptoms
        </p>
        <div class="mt-4">
            @if (User.Identity.IsAuthenticated)
            {
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Index"
                       class="btn btn-light btn-lg me-3">
                        <i class="bi bi-speedometer2"></i> Go to Dashboard
                    </a>
                }
                else
                {
                    <a asp-controller="Patient" asp-action="Symptoms"
                       class="btn btn-light btn-lg me-3">
                        <i class="bi bi-heart-pulse"></i> Check Symptoms
                    </a>
                    <a asp-controller="Patient" asp-action="Index"
                       class="btn btn-outline-light btn-lg">
                        <i class="bi bi-house"></i> My Dashboard
                    </a>
                }
            }
            else
            {
                <a asp-controller="Auth" asp-action="Register"
                   class="btn btn-light btn-lg me-3">
                    <i class="bi bi-person-plus"></i> Get Started
                </a>
                <a asp-controller="Auth" asp-action="Login"
                   class="btn btn-outline-light btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Login
                </a>
            }
        </div>
    </div>
</div>

<!-- ✅ Features Section -->
<div class="container mt-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-3">
                <div class="card-body">
                    <h1>🩺</h1>
                    <h5 class="mt-3">Symptom Analysis</h5>
                    <p class="text-muted">
                        Enter your symptoms and get instant analysis
                        with severity level assessment
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-3">
                <div class="card-body">
                    <h1>🔬</h1>
                    <h5 class="mt-3">Test Recommendations</h5>
                    <p class="text-muted">
                        Get personalized medical test recommendations
                        with clear explanations
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100 p-3">
                <div class="card-body">
                    <h1>💡</h1>
                    <h5 class="mt-3">Explainable AI</h5>
                    <p class="text-muted">
                        Every recommendation comes with a clear reason
                        so you can make informed decisions
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ✅ How It Works -->
<div class="bg-light py-5 mt-4">
    <div class="container">
        <h3 class="text-center mb-4">How It Works</h3>
        <div class="row text-center">
            <div class="col-md-3 mb-3">
                <div class="card shadow p-3">
                    <h2>1️⃣</h2>
                    <h6 class="mt-2">Register</h6>
                    <p class="text-muted small">Create your account</p>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow p-3">
                    <h2>2️⃣</h2>
                    <h6 class="mt-2">Enter Symptoms</h6>
                    <p class="text-muted small">Select your symptoms</p>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow p-3">
                    <h2>3️⃣</h2>
                    <h6 class="mt-2">AI Analysis</h6>
                    <p class="text-muted small">System analyzes your data</p>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow p-3">
                    <h2>4️⃣</h2>
                    <h6 class="mt-2">Get Results</h6>
                    <p class="text-muted small">Receive test recommendations</p>
                </div>
            </div>
        </div>
    </div>
</div>