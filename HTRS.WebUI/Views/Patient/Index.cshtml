@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2>Welcome, @ViewBag.PatientName 👋</h2>
            <hr />
        </div>
    </div>

    <div class="row mt-3">
        <!-- ✅ Quick Actions -->
        <div class="col-md-4">
            <div class="card shadow text-center p-3">
                <h5>New Symptom Check</h5>
                <p>Submit your symptoms and get test recommendations</p>
                <a asp-controller="Patient" asp-action="Symptoms"
                   class="btn btn-primary">Start Now</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow text-center p-3">
                <h5>My Sessions</h5>
                <p>View your previous symptom sessions</p>
                <a asp-controller="Patient" asp-action="Sessions"
                   class="btn btn-outline-primary">View All</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow text-center p-3">
                <h5>My Profile</h5>
                <p>View and update your profile</p>
                <a asp-controller="Patient" asp-action="CreateProfile"
                   class="btn btn-outline-secondary">View Profile</a>
            </div>
        </div>
    </div>

    <!-- ✅ Recent Sessions -->
    <div class="row mt-4">
        <div class="col-md-12">
            <h4>Recent Sessions</h4>
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Severity</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Sessions != null)
                    {
                        @foreach (var session in ViewBag.Sessions)
                        {
                            <tr>
                                <td>@session.SessionDate.ToString("dd MMM yyyy")</td>
                                <td>@session.SeverityLevel</td>
                                <td>
                                    <a asp-controller="Patient"
                                       asp-action="SessionDetail"
                                       asp-route-id="@session.Id"
                                       class="btn btn-sm btn-info">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">
                                No sessions yet
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>